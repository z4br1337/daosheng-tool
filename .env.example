# SQLite（默认）。本地可用相对路径。
# Docker / 服务器上建议使用绝对路径，例如：file:/app/prisma/data.db
# 若将空持久卷挂载到 /app/prisma，请改用例如 file:/data/data.db 并把卷挂到 /data，避免遮住 schema。
DATABASE_URL="file:./prisma/data.db"

# iron-session 加密密钥，至少 32 字符随机串
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# 火山方舟豆包
ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_MODEL="doubao-seed-2-0-lite-260215"

# 管理员学号硬编码为 240153484（见 src/lib/bootstrap.ts）
# 注册时使用该学号会自动成为管理员，无需审批。
