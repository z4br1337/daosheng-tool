generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String   @id @default(cuid())
  studentNo    String   @unique
  name         String
  passwordHash String
  role         UserRole @default(USER)
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Class {
  id        String    @id @default(cuid())
  name      String
  students  Student[]
  createdAt DateTime  @default(now())
}

model Student {
  id        String          @id @default(cuid())
  classId   String
  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentNo String?
  name      String
  records   ProfileRecord[]
  analyses  AiAnalysis[]
  createdAt DateTime        @default(now())

  @@unique([classId, studentNo])
  @@index([classId])
}

enum ReporterRole {
  MENTOR
  COMMITTEE
}

model ProfileRecord {
  id                 String       @id @default(cuid())
  studentId          String
  student            Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  role               ReporterRole
  reporterName       String
  attendance         String?
  learningConfusion  String?
  learningAttitude   String?
  learningNotes      String?
  mentalState        String?
  mentalNotes        String?
  createdAt          DateTime     @default(now())

  @@index([studentId])
}

model AiAnalysis {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  summary    String
  issuesJson String
  createdAt  DateTime @default(now())

  @@index([studentId])
}
